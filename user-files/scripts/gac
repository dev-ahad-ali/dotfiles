#!/bin/bash

# ─────────────────────────────────────────
#  gac.sh — Quick git add & commit
#  Usage:
#    ./gac.sh "your commit message"
#    ./gac.sh
# ─────────────────────────────────────────

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Check if we're inside a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${RED}✗ Not a git repository. Please run this inside a git project.${NC}"
  exit 1
fi

# Get commit message from argument or prompt
if [ -n "$1" ]; then
  COMMIT_MSG="$*"
else
  echo -e "${CYAN}Enter commit message:${NC} "
  read -r COMMIT_MSG
fi

# Validate message is not empty
if [ -z "$COMMIT_MSG" ]; then
  echo -e "${RED}✗ Commit message cannot be empty.${NC}"
  exit 1
fi

# Show what's changing
echo -e "\n${YELLOW}── Staged changes ──────────────────────${NC}"
git status --short
echo ""

# git add .
echo -e "${CYAN}➜ Running: git add .${NC}"
git add .

# git commit
echo -e "${CYAN}➜ Running: git commit -m \"${COMMIT_MSG}\"${NC}"
if git commit -m "$COMMIT_MSG"; then
  echo -e "\n${GREEN}✔ Committed successfully!${NC}"
  echo -e "${GREEN}  Message: \"${COMMIT_MSG}\"${NC}"
else
  echo -e "\n${RED}✗ Commit failed. Nothing new to commit, or another error occurred.${NC}"
  exit 1
fi
